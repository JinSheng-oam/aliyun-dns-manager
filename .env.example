# 阿里云 DNS 管理器 环境变量模板

# [必填] 管理后台登录密码。
# 出于安全考虑，未设置时应用将拒绝进入管理后台。
ADMIN_PASSWORD=your_dashboard_password

# [推荐] 会话签名密钥。
# 未设置时会退回使用 ADMIN_PASSWORD 作为签名密钥；公开部署建议单独设置强随机字符串。
SESSION_SECRET=your_random_session_secret

# [可选] 数据存储加密密钥。
# 设置后，本地存储的 AccessKeys 将使用 AES-256-GCM 进行加密。
# 更改此密钥会导致之前加密的数据无法读取，请妥善保管。
ENCRYPTION_KEY=your_random_encryption_key_string

# [可选] 运行端口，默认为 3000
PORT=3999

# [可选] 是否强制使用 HTTPS Cookie。
# 如果您通过 Nginx 反向代理 + SSL 提供 HTTPS 访问，请设置为 true。
# 如果直接通过 HTTP 访问（如 http://ip:3999），请不要设置或设为 false。
# FORCE_HTTPS_COOKIE=true

# [可选] 监听 IP 配置
# 监听的IP地址，默认为 0.0.0.0 (监听所有接口)
# 设置为 127.0.0.1 仅允许本机访问
# 设置为 :: 监听所有 IPv6/IPv4 接口
HOST=0.0.0.0

# [可选] 登录防护配置
# 登录尝试频率限制窗口（秒），默认为 60 秒
LOGIN_WINDOW_SECONDS=60
# 限制窗口内允许的最大失败次数，默认为 5 次
LOGIN_MAX_ATTEMPTS=5
